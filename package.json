{
	"name": "smart-explorer",
	"version": "0.3.3",
	"description": "An alternative file explorer with custom sorting, grouping, and filtering.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "node --experimental-vm-modules node_modules/.bin/jest"
	},
	"keywords": [
		"obsidian",
		"file-explorer",
		"sorting",
		"filtering"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/rogerdigital/smart-explorer.git"
	},
	"license": "MIT",
	"devDependencies": {
		"@types/jest": "^29.5.12",
		"@types/node": "^16.11.6",
		"esbuild": "^0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.2.9",
		"jest": "^29.7.0",
		"ts-jest": "^29.1.1",
		"tslib": "^2.4.0",
		"typescript": "^5.8.3"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
